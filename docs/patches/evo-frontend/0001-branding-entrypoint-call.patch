From 52ca4b7120dd24afe1775402d0cab4e09935e0db Mon Sep 17 00:00:00 2001
From: Luiz Carlos Ceconi <luizcceconi@gmail.com>
Date: Fri, 22 May 2026 22:36:33 -0300
Subject: [PATCH] custom: add branding entrypoint hook

Minimal white-label patch to invoke the dedicated branding runtime script from the upstream frontend entrypoint.
---
 docker-entrypoint.sh | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/docker-entrypoint.sh b/docker-entrypoint.sh
index ec991d4..abeefbf 100755
--- a/docker-entrypoint.sh
+++ b/docker-entrypoint.sh
@@ -32,4 +32,6 @@ if [ "$APP_ENV" = "development" ]; then
 fi
 
 
+[ -f /docker-entrypoint.d/branding-entrypoint.sh ] && sh /docker-entrypoint.d/branding-entrypoint.sh
+
 exec "$@"
-- 
